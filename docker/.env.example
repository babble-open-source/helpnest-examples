# Database
POSTGRES_DB=helpnest
POSTGRES_USER=helpnest
POSTGRES_PASSWORD=change-me-strong-password

# Auth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-to-a-random-secret
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Custom domain (optional)
# Point any domain at this HelpNest instance and serve a workspace at the root.
# Example: support.trybabble.io → babble workspace
# Leave blank if you're using the default /{slug}/help path.
HELPNEST_CUSTOM_DOMAIN=
HELPNEST_CUSTOM_DOMAIN_SLUG=

# AI features (optional — needed for Ask AI and vector search)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
